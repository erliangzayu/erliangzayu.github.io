<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OC 角色数据配置工具</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .table-input { @apply border border-gray-300 px-2 py-1 w-full rounded focus:outline-none focus:border-blue-500 text-sm; }
        .tab-btn-active { @apply border-b-2 border-blue-500 text-blue-600 font-bold; }
    </style>
</head>
<body class="bg-gray-100 h-screen flex flex-col font-sans">

    <header class="bg-white shadow px-6 py-3 flex justify-between items-center shrink-0">
        <div class="flex items-center gap-4">
            <h1 class="text-xl font-bold text-gray-800">🎭 OC 角色数据配置工具</h1>
            <label class="bg-amber-500 hover:bg-amber-600 text-white px-3 py-1.5 rounded text-xs font-medium cursor-pointer transition">
                📥 导入已有 JSON
                <input type="file" id="import-file" accept=".json" class="hidden" onchange="importJSON(event)">
            </label>
        </div>
        <div class="space-x-2">
            <button onclick="copyJSON()" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded text-sm font-medium transition">一键复制 JSON</button>
            <button onclick="downloadJSON()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded text-sm font-medium transition">下载 .json 文件</button>
        </div>
    </header>

    <main class="flex-1 flex overflow-hidden p-4 gap-4">
        
        <section class="w-1/2 bg-white rounded-lg shadow flex flex-col overflow-hidden">
            <div class="flex border-b border-gray-200 bg-gray-50 shrink-0 text-sm">
                <button onclick="switchTab('m1')" id="tab-m1" class="px-4 py-3 text-gray-600 hover:text-blue-500 tab-btn-active">1. 基础信息</button>
                <button onclick="switchTab('m2')" id="tab-m2" class="px-4 py-3 text-gray-600 hover:text-blue-500">2. 固定日程表</button>
                <button onclick="switchTab('m3')" id="tab-m3" class="px-4 py-3 text-gray-600 hover:text-blue-500">3. 随机事件表</button>
                <button onclick="switchTab('m4')" id="tab-m4" class="px-4 py-3 text-gray-600 hover:text-blue-500">4. 地点随机话术</button>
            </div>

            <div class="flex-1 overflow-y-auto p-4 space-y-4">
                
                <div id="content-m1" class="tab-content space-y-4">
                    <h3 class="font-bold text-gray-700 text-base border-b pb-1">角色全局信息</h3>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-gray-500 mb-1">角色名 (name)</label>
                            <input type="text" id="m1-name" value="陈墨" oninput="updateAll()" class="table-input text-base font-medium">
                        </div>
                        <div>
                            <label class="block text-xs text-gray-500 mb-1">头像路径 (avatar)</label>
                            <input type="text" id="m1-avatar" value="images/avatar/chenmo.png" oninput="updateAll()" class="table-input text-base">
                        </div>
                    </div>
                </div>

                <div id="content-m2" class="tab-content hidden space-y-2">
                    <div class="flex justify-between items-center mb-1">
                        <h3 class="font-bold text-gray-700">固定日程配置 (按行填写)</h3>
                        <button onclick="addRow('m2')" class="bg-green-600 hover:bg-green-700 text-white px-2 py-1 rounded text-xs">+ 增加日程行</button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[600px]">
                            <thead>
                                <tr class="bg-gray-100 text-xs text-gray-600">
                                    <th class="p-1 border w-24">适用周数 (如 1-5)</th>
                                    <th class="p-1 border w-32">时间段 (HH:MM-HH:MM)</th>
                                    <th class="p-1 border w-24">地点 (area)</th>
                                    <th class="p-1 border w-24">类型 (type)</th>
                                    <th class="p-1 border">动作名称 (actionName)</th>
                                    <th class="p-1 border w-12 text-center">操作</th>
                                </tr>
                            </thead>
                            <tbody id="tbody-m2">
                                <tr class="text-sm">
                                    <td class="p-1 border"><input type="text" value="1-5" class="table-input font-mono" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="00:00-07:00" class="table-input font-mono" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="家中" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="sleep" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="睡觉" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border text-center"><button onclick="deleteRow(this)" class="text-red-500 hover:text-red-700 font-bold">×</button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div id="content-m3" class="tab-content hidden space-y-2">
                    <div class="flex justify-between items-center mb-1">
                        <h3 class="font-bold text-gray-700">随机事件配置</h3>
                        <button onclick="addRow('m3')" class="bg-green-600 hover:bg-green-700 text-white px-2 py-1 rounded text-xs">+ 增加事件分支</button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[800px]">
                            <thead>
                                <tr class="bg-gray-100 text-xs text-gray-600">
                                    <th class="p-1 border w-20">事件组ID</th>
                                    <th class="p-1 border w-16">触发周数</th>
                                    <th class="p-1 border w-28">时间范围</th>
                                    <th class="p-1 border w-16">概率(rate)</th>
                                    <th class="p-1 border w-20">地点</th>
                                    <th class="p-1 border w-16">类型</th>
                                    <th class="p-1 border">动作名称</th>
                                    <th class="p-1 border w-16">持续(persist)</th>
                                    <th class="p-1 border">剧情提示(tip)</th>
                                    <th class="p-1 border w-16">必选(mandatory)</th>
                                    <th class="p-1 border w-10 text-center">⚙️</th>
                                </tr>
                            </thead>
                            <tbody id="tbody-m3">
                                <tr class="text-sm">
                                    <td class="p-1 border"><input type="text" value="ev_01" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="1-5" class="table-input font-mono" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="12:00-13:00" class="table-input font-mono" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="30" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="天台" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="rest" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="吹风看风景" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="否" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="是" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border text-center"><button onclick="deleteRow(this)" class="text-red-500 hover:text-red-700 font-bold">×</button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div id="content-m4" class="tab-content hidden space-y-2">
                    <div class="flex justify-between items-center mb-1">
                        <h3 class="font-bold text-gray-700">地点随机话术配置</h3>
                        <button onclick="addRow('m4')" class="bg-green-600 hover:bg-green-700 text-white px-2 py-1 rounded text-xs">+ 增加话术项</button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-gray-100 text-xs text-gray-600">
                                    <th class="p-1 border w-32">地点 (area)</th>
                                    <th class="p-1 border w-32">活动类型 (type)</th>
                                    <th class="p-1 border">话术内容 (单条)</th>
                                    <th class="p-1 border w-12 text-center">操作</th>
                                </tr>
                            </thead>
                            <tbody id="tbody-m4">
                                <tr class="text-sm">
                                    <td class="p-1 border"><input type="text" value="咖啡厅" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="rest" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border"><input type="text" value="靠窗的位置风景不错。" class="table-input" oninput="updateAll()"></td>
                                    <td class="p-1 border text-center"><button onclick="deleteRow(this)" class="text-red-500 hover:text-red-700 font-bold">×</button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </section>

        <section class="w-1/2 bg-gray-900 rounded-lg shadow flex flex-col overflow-hidden text-gray-200 font-mono text-sm relative">
            <div id="validator-bar" class="bg-gray-800 px-4 py-2 text-xs border-b border-gray-700 flex flex-col gap-1 max-h-32 overflow-y-auto shrink-0">
                <span class="text-green-400 font-bold">✅ 状态正常</span>
            </div>
            <pre class="flex-1 p-4 overflow-auto bg-gray-950 text-emerald-400 select-all" id="json-output"></pre>
        </section>
    </main>

    <script>
        // --- 工具函数：解析周数格式 "1-5" -> [1,2,3,4,5] ---
        function parseWeeks(weekStr) {
            if (!weekStr) return [];
            let str = weekStr.toString().replace(/\[|\]/g, '').trim();
            if (str.includes('-')) {
                const [start, end] = str.split('-').map(Number);
                const arr = [];
                for (let i = start; i <= end; i++) arr.push(i);
                return arr;
            }
            return str.split(/[,，]/).map(item => parseInt(item.trim())).filter(n => !isNaN(n));
        }

        // 格式化输出数组/字符串
        function formatWeeksOutput(arr) {
            return arr;
        }

        // --- 核心逻辑：从表格生成 JSON ---
        function generateJSON() {
            const result = {};
            const errors = [];

            // 1. 基础字段
            result.name = document.getElementById('m1-name').value.trim();
            result.avatar = document.getElementById('m1-avatar').value.trim();
            
            // 2. 解析固定日程（按 week 聚合）
            const m2Rows = document.querySelectorAll('#tbody-m2 tr');
            const scheduleGroup = {}; // 用来归类相同 week 的日常

            m2Rows.forEach(row => {
                const inputs = row.querySelectorAll('input');
                if(inputs.length < 5) return;
                const rawWeek = inputs[0].value.trim();
                const timeRange = inputs[1].value.trim();
                const area = inputs[2].value.trim();
                const type = inputs[3].value.trim();
                const actionName = inputs[4].value.trim();

                if (!rawWeek || !timeRange) return;

                const weekArr = parseWeeks(rawWeek);
                const weekKey = JSON.stringify(weekArr); // 用作唯一标识键

                if (!scheduleGroup[weekKey]) {
                    scheduleGroup[weekKey] = {
                        week: weekArr,
                        schedule: []
                    };
                }
                scheduleGroup[weekKey].schedule.push({
                    timeRange, area, type, actionName
                });
            });
            result.baseSchedule = Object.values(scheduleGroup);

            // 3. 解析随机事件
            result.randomEvents = [];
            const m3Rows = document.querySelectorAll('#tbody-m3 tr');
            const groupProbCounter = {};

            m3Rows.forEach(row => {
                const inputs = row.querySelectorAll('input');
                if(inputs.length < 10) return;
                const id = inputs[0].value.trim();
                const rawWeek = inputs[1].value.trim();
                const timeRange = inputs[2].value.trim();
                const rate = parseInt(inputs[3].value.trim(), 10) || 0;
                const area = inputs[4].value.trim();
                const type = inputs[5].value.trim();
                const actionName = inputs[6].value.trim();
                const persistStr = inputs[7].value.trim();
                const tip = inputs[8].value.trim();
                const mandatoryStr = inputs[9].value.trim();

                if (!id && !actionName) return;

                if (id) {
                    groupProbCounter[id] = (groupProbCounter[id] || 0) + rate;
                }

                const eventObj = {
                    id,
                    week: parseWeeks(rawWeek),
                    timeRange,
                    rate,
                    area,
                    type,
                    actionName,
                    persist: persistStr === '是' || persistStr === 'true',
                    tip: tip || "",
                    isMandatory: mandatoryStr === '是' || mandatoryStr === 'true'
                };
                result.randomEvents.push(eventObj);
            });

            // 校验概率
            Object.keys(groupProbCounter).forEach(gId => {
                if (groupProbCounter[gId] !== 100) {
                    errors.push(`❌ 随机事件组 [${gId}] 概率总和为 ${groupProbCounter[gId]}%，不等于 100%`);
                }
            });

            // 4. 解析地点话术
            result.locationRandomActions = {};
            const m4Rows = document.querySelectorAll('#tbody-m4 tr');
            m4Rows.forEach(row => {
                const inputs = row.querySelectorAll('input');
                if(inputs.length < 3) return;
                const area = inputs[0].value.trim();
                const type = inputs[1].value.trim();
                const text = inputs[2].value.trim();

                if (!area || !type || !text) return;

                if (!result.locationRandomActions[area]) result.locationRandomActions[area] = {};
                if (!result.locationRandomActions[area][type]) result.locationRandomActions[area][type] = [];
                result.locationRandomActions[area][type].push(text);
            });

            // 输出
            document.getElementById('json-output').textContent = JSON.stringify(result, null, 2);
            renderValidator(errors);
        }

        // --- 核心反向解析：从 JSON 还原表格 ---
        function importJSON(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const data = JSON.parse(e.target.result);
                    
                    // 1. 还原基础信息
                    document.getElementById('m1-name').value = data.name || "";
                    document.getElementById('m1-avatar').value = data.avatar || "";

                    // 2. 还原固定日程表
                    const tbodyM2 = document.getElementById('tbody-m2');
                    tbodyM2.innerHTML = "";
                    if (data.baseSchedule && Array.isArray(data.baseSchedule)) {
                        data.baseSchedule.forEach(item => {
                            const weekStr = item.week ? item.week.join(',') : "";
                            if(item.schedule && Array.isArray(item.schedule)) {
                                item.schedule.forEach(sche => {
                                    const tr = document.createElement('tr');
                                    tr.className = "text-sm";
                                    tr.innerHTML = `
                                        <td class="p-1 border"><input type="text" value="${weekStr}" class="table-input font-mono" oninput="updateAll()"></td>
                                        <td class="p-1 border"><input type="text" value="${sche.timeRange || ''}" class="table-input font-mono" oninput="updateAll()"></td>
                                        <td class="p-1 border"><input type="text" value="${sche.area || ''}" class="table-input" oninput="updateAll()"></td>
                                        <td class="p-1 border"><input type="text" value="${sche.type || ''}" class="table-input" oninput="updateAll()"></td>
                                        <td class="p-1 border"><input type="text" value="${sche.actionName || ''}" class="table-input" oninput="updateAll()"></td>
                                        <td class="p-1 border text-center"><button onclick="deleteRow(this)" class="text-red-500 hover:text-red-700 font-bold">×</button></td>
                                    `;
                                    tbodyM2.appendChild(tr);
                                });
                            }
                        });
                    }

                    // 3. 还原随机事件表
                    const tbodyM3 = document.getElementById('tbody-m3');
                    tbodyM3.innerHTML = "";
                    if (data.randomEvents && Array.isArray(data.randomEvents)) {
                        data.randomEvents.forEach(ev => {
                            const tr = document.createElement('tr');
                            tr.className = "text-sm";
                            tr.innerHTML = `
                                <td class="p-1 border"><input type="text" value="${ev.id || ''}" class="table-input" oninput="updateAll()"></td>
                                <td class="p-1 border"><input type="text" value="${ev.week ? ev.week.join(',') : ''}" class="table-input font-mono" oninput="updateAll()"></td>
                                <td class="p-1 border"><input type="text" value="${ev.timeRange || ''}" class="table-input font-mono" oninput="updateAll()"></td>
                                <td class="p-1 border"><input type="text" value="${ev.rate || 0}" class="table-input" oninput="updateAll()"></td>
                                <td class="p-1 border"><input type="text" value="${ev.area || ''}" class="table-input" oninput="updateAll()"></td>
                                <td class="p-1 border"><input type="text" value="${ev.type || ''}" class="table-input" oninput="updateAll()"></td>
                                <td class="p-1 border"><input type="text" value="${ev.actionName || ''}" class="table-input" oninput="updateAll()"></td>
                                <td class="p-1 border"><input type="text" value="${ev.persist ? '是' : '否'}" class="table-input" oninput="updateAll()"></td>
                                <td class="p-1 border"><input type="text" value="${ev.tip || ''}" class="table-input" oninput="updateAll()"></td>
                                <td class="p-1 border"><input type="text" value="${ev.isMandatory ? '是' : '否'}" class="table-input" oninput="updateAll()"></td>
                                <td class="p-1 border text-center"><button onclick="deleteRow(this)" class="text-red-500 hover:text-red-700 font-bold">×</button></td>
                            `;
                            tbodyM3.appendChild(tr);
                        });
                    }

                    // 4. 还原地点话术表
                    const tbodyM4 = document.getElementById('tbody-m4');
                    tbodyM4.innerHTML = "";
                    if (data.locationRandomActions) {
                        for (const area in data.locationRandomActions) {
                            for (const type in data.locationRandomActions[area]) {
                                const actionList = data.locationRandomActions[area][type];
                                if (Array.isArray(actionList)) {
                                    actionList.forEach(text => {
                                        const tr = document.createElement('tr');
                                        tr.className = "text-sm";
                                        tr.innerHTML = `
                                            <td class="p-1 border"><input type="text" value="${area}" class="table-input" oninput="updateAll()"></td>
                                            <td class="p-1 border"><input type="text" value="${type}" class="table-input" oninput="updateAll()"></td>
                                            <td class="p-1 border"><input type="text" value="${text}" class="table-input" oninput="updateAll()"></td>
                                            <td class="p-1 border text-center"><button onclick="deleteRow(this)" class="text-red-500 hover:text-red-700 font-bold">×</button></td>
                                        `;
                                        tbodyM4.appendChild(tr);
                                    });
                                }
                            }
                        }
                    }

                    updateAll();
                    alert("📅 JSON 数据导入并解析成功！已还原至左侧表格。");
                } catch (err) {
                    alert("❌ 导入失败，请确保文件是合法的 JSON 格式。错误信息: " + err.message);
                }
            };
            reader.readAsText(file);
        }

        // --- 界面交互 UI 控制 ---
        function renderValidator(errors) {
            const container = document.getElementById('validator-bar');
            if (errors.length === 0) {
                container.innerHTML = `<span class="text-green-400 font-bold">✅ 所有配置校验通过，数据格式完美契合游戏逻辑！</span>`;
            } else {
                container.innerHTML = errors.map(err => `<span class="text-rose-400 font-medium">${err}</span>`).join('');
            }
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('[id^="tab-"]').forEach(el => el.classList.remove('tab-btn-active'));
            document.getElementById(`content-${tabId}`).classList.remove('hidden');
            document.getElementById(`tab-${tabId}`).classList.add('tab-btn-active');
        }

        function addRow(module) {
            const tbody = document.getElementById(`tbody-${module}`);
            const tr = document.createElement('tr');
            tr.className = "text-sm";
            
            if (module === 'm2') {
                tr.innerHTML = `
                    <td class="p-1 border"><input type="text" value="1-5" class="table-input font-mono" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="00:00-00:00" class="table-input font-mono" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border text-center"><button onclick="deleteRow(this)" class="text-red-500 hover:text-red-700 font-bold">×</button></td>
                `;
            } else if (module === 'm3') {
                tr.innerHTML = `
                    <td class="p-1 border"><input type="text" value="ev_01" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="1-5" class="table-input font-mono" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="00:00-00:00" class="table-input font-mono" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="50" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="否" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="是" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border text-center"><button onclick="deleteRow(this)" class="text-red-500 hover:text-red-700 font-bold">×</button></td>
                `;
            } else if (module === 'm4') {
                tr.innerHTML = `
                    <td class="p-1 border"><input type="text" value="" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border"><input type="text" value="" class="table-input" oninput="updateAll()"></td>
                    <td class="p-1 border text-center"><button onclick="deleteRow(this)" class="text-red-500 hover:text-red-700 font-bold">×</button></td>
                `;
            }
            tbody.appendChild(tr);
            updateAll();
        }

        function deleteRow(button) {
            button.closest('tr').remove();
            updateAll();
        }

        function updateAll() {
            generateJSON();
        }

        function copyJSON() {
            const jsonText = document.getElementById('json-output').textContent;
            navigator.clipboard.writeText(jsonText).then(() => {
                alert('🚀 JSON 已经成功复制到您的剪贴板！');
            });
        }

        function downloadJSON() {
            const jsonText = document.getElementById('json-output').textContent;
            const roleName = document.getElementById('m1-name').value.trim() || 'role';
            const blob = new Blob([jsonText], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `${roleName}.json`;
            a.click();
            URL.revokeObjectURL(url);
        }

        window.onload = function() {
            generateJSON();
        };
    </script>
</body>
</html>
